# ── Backend ───────────────────────────────────────────────────────────────────

# Absolute path where the pipeline writes/reads its parquet cache.
# Default (local dev): grant_radar/data/processed/
# Default (Docker):    /app/data/processed  (mounted volume)
GRANT_RADAR_CACHE_DIR=

# Comma-separated CORS origins the backend will accept.
CORS_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────

# Base URL of the backend API, used by the Next.js dev server proxy.
# Leave empty when running behind a reverse proxy or using docker-compose
# (Next.js rewrites handle /api/* → backend automatically).
NEXT_PUBLIC_API_URL=
